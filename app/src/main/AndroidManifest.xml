<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.HopeHouse">
        <activity
                android:name=".ui.activities.ProfileActivity"
                android:exported="false"
                android:label="@string/app_name" />
            <activity
                android:name=".ui.activities.DonationActivity"
                android:exported="false"
                android:label="@string/app_name" />
            <activity
                android:name=".ui.activities.EventsActivity"
                android:exported="false"
                android:label="@string/app_name" />
            <activity
                android:name=".ui.activities.VolunteerActivity"
                android:exported="false"
                android:label="@string/app_name" />
            <activity
                android:name=".ui.activities.FoodRescueActivity"
                android:exported="false"
                android:label="@string/app_name" />
            <activity
                android:name=".ui.activities.NgoDetailActivity"
                android:exported="false"
                android:label="@string/app_name" />
            <activity
                android:name=".ui.activities.NgoListingActivity"
                android:exported="false"
                android:label="@string/app_name" />
            <activity
                android:name=".ui.activities.HomeActivity"
                android:exported="false"
                android:label="@string/app_name" />

            <activity
                android:name=".ui.activities.SignupActivity"
                android:exported="false"
                android:label="@string/app_name" />

            <activity
                android:name=".MainActivity"
                android:exported="true"
                android:label="@string/app_name"
                android:theme="@style/Theme.HopeHouse">
                <intent-filter>
                    <action android:name="android.intent.action.MAIN" />

                    <category android:name="android.intent.category.LAUNCHER" />
                </intent-filter>
            </activity>
    </application>

</manifest>