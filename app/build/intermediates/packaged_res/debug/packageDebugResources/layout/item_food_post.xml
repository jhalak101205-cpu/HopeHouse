<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardFoodPost"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardBackgroundColor="@color/hope_card"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/tvFoodLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Location"
            android:textStyle="bold"
            android:textColor="@color/hope_blue_700" />

        <TextView
            android:id="@+id/tvFoodMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Quantity &amp; Time"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvFoodStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Status"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClaimFood"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Claim Food"
            android:layout_marginTop="10dp"
            android:backgroundTint="@color/hope_green_500"
            android:textColor="@color/white" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>

