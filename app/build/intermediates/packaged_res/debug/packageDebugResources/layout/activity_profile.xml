<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/hope_bg">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarProfile"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/hope_card"
        app:title="Profile Dashboard"
        app:titleTextColor="@color/hope_blue_700"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollProfile"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbarProfile"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvProfileRole"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Role"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="@color/hope_green_700" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Your activity (demo counters)"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginTop="16dp" />

            <TextView
                android:id="@+id/tvDonationMoney"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Donations (Money): 0"
                android:layout_marginTop="12dp" />

            <TextView
                android:id="@+id/tvDonationItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Donations (Items): 0"
                android:layout_marginTop="6dp" />

            <TextView
                android:id="@+id/tvVolunteerCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Volunteering: 0"
                android:layout_marginTop="6dp" />

            <TextView
                android:id="@+id/tvFoodPostsCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Food posts: 0"
                android:layout_marginTop="6dp" />

            <TextView
                android:id="@+id/tvFoodClaimsCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Food claimed: 0"
                android:layout_marginTop="6dp" />

            <TextView
                android:id="@+id/tvEventRegistrations"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Event registrations: 0"
                android:layout_marginTop="6dp" />

            <Button
                android:id="@+id/btnBackToHome"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Back to Home"
                android:layout_marginTop="18dp"
                android:backgroundTint="@color/hope_blue_500"
                android:textColor="@color/white" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>

